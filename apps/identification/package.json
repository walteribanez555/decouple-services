  "main": "index.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "build:prod": "node esbuild.config.js --prod",
    "build:lambda": "node esbuild.config.js --target=lambda",
    "build:lambda:prod": "node esbuild.config.js --prod --target=lambda",
    "build:ecs": "node esbuild.config.js --target=ecs",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/main.ts",
    "start": "node --env-file=.env dist/main.js",
    "start:lambda": "node dist/index.js",
    "clean": "rm -rf dist",
    "migrate": "ts-node --project migrations/tsconfig.json migrations/runner.ts",
    "migrate:create": "ts-node --project migrations/tsconfig.json migrations/create.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
