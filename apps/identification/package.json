  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "hono": "^4.6.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1053.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.28.0",
