# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across editors and IDEs.

root = true

# ── Defaults — all files ──────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true

# ── TypeScript / JavaScript ───────────────────────────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# ── Dart / Flutter ────────────────────────────────────────────────────────────
[*.dart]
indent_size = 2

# ── JSON ──────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ── YAML (workflows, dependabot, pubspec) ─────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false   # trailing spaces = intentional line breaks

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_size              = 2
end_of_line              = lf

# ── Makefile — must use tabs ──────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ── Lockfiles — do not reformat ───────────────────────────────────────────────
[{package-lock.json,yarn.lock,pubspec.lock,Podfile.lock}]
indent_size              = unset
trim_trailing_whitespace = false
insert_final_newline     = false
